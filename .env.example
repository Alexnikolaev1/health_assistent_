# ==========================================
# MAX Bot
# ==========================================
MAX_BOT_TOKEN=your_max_bot_token_here
MAX_API_URL=https://botapi.max.ru

# ==========================================
# Yandex Cloud / YandexGPT
# ==========================================
YANDEX_CLOUD_FOLDER_ID=your_folder_id
YANDEX_GPT_API_KEY=your_api_key_or_iam_token
# Используй: yandexgpt/latest | yandexgpt-lite/latest | general
YANDEX_GPT_MODEL=yandexgpt/latest

# ==========================================
# База данных — выберите один вариант
# ==========================================

# Вариант A: Vercel Postgres
POSTGRES_URL=postgres://user:password@host:5432/dbname
POSTGRES_PRISMA_URL=postgres://user:password@host:5432/dbname?pgbouncer=true
POSTGRES_URL_NON_POOLING=postgres://user:password@host:5432/dbname

# Вариант B: Supabase (альтернатива)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key

# ==========================================
# Upstash QStash (напоминания)
# ==========================================
QSTASH_TOKEN=your_qstash_token
QSTASH_CURRENT_SIGNING_KEY=your_current_signing_key
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key

# ==========================================
# Госуслуги (тестовый контур, опционально)
# ==========================================
GOSUSLUGI_CLIENT_ID=your_gosuslugi_client_id
GOSUSLUGI_CLIENT_SECRET=your_gosuslugi_client_secret
GOSUSLUGI_BASE_URL=https://esia-portal1.test.gosuslugi.ru

# ==========================================
# Внутренняя безопасность
# ==========================================
# Опционально: заголовок X-Webhook-Secret на POST /api/webhook (если не задан — проверка отключена)
WEBHOOK_SECRET=

# Секрет для проверки cron-запросов от Vercel
CRON_SECRET=generate_a_random_secret_here

# URL вашего деплоя (без слэша в конце)
APP_URL=https://your-app.vercel.app
